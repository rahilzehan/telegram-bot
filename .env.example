# Copy this file to .env and fill in your values.
# Local testing only - no cloud config required. Do not commit your .env.

# Telegram bot token from @BotFather (required)
BOT_TOKEN=

# Admin Telegram username, with or without @ (required)
ADMIN_USERNAME=

# Shortener URL opened by the "Unlock Download" button (required)
SHORTENER_URL=

# Website opened by the "Open Website" button (required)
WEBSITE_URL=

# Direct file download URL, e.g. MediaFire, opened by "Download File" (required)
MEDIAFIRE_URL=
